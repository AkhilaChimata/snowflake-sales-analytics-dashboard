--Creating the Silver Layer
CREATE OR REPLACE TABLE SILVER.ORDERS_CLEAN AS SELECT O_ORDERKEY, O_CUSTKEY, O_ORDERSTATUS, O_TOTALPRICE, O_ORDERDATE,
YEAR(O_ORDERDATE) AS ORDER_YEAR 
FROM BRONZE.ORDERS_RAW WHERE O_TOTALPRICE > 10000;
