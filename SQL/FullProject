--creating dashboards
--calculating total revenue
SELECT
    ROUND(SUM(O_TOTALPRICE), 2) AS TOTAL_REVENUE
FROM SILVER.ORDERS_INCREMENTAL;

--KPIs
SELECT
    COUNT(*) AS TOTAL_ORDERS
FROM SILVER.ORDERS_INCREMENTAL;

--KPIs Average order value
SELECT
    ROUND(AVG(O_TOTALPRICE), 2) AS AVG_ORDER_VALUE
FROM SILVER.ORDERS_INCREMENTAL;

--KPI Highest order value
SELECT
    MAX(O_TOTALPRICE) AS HIGHEST_ORDER
FROM SILVER.ORDERS_INCREMENTAL;

--chart 1 - Monthly Revenue trend
SELECT
    YEAR(O_ORDERDATE) AS ORDER_YEAR,
    MONTH(O_ORDERDATE) AS ORDER_MONTH,
    ROUND(SUM(O_TOTALPRICE), 2) AS MONTHLY_REVENUE
FROM SILVER.ORDERS_INCREMENTAL
GROUP BY
    YEAR(O_ORDERDATE),
    MONTH(O_ORDERDATE)
ORDER BY
    ORDER_YEAR,
    ORDER_MONTH;

--TOP CUSTOMERS
SELECT
    O_CUSTKEY,
    ROUND(SUM(O_TOTALPRICE), 2) AS TOTAL_SPENT
FROM SILVER.ORDERS_INCREMENTAL
GROUP BY O_CUSTKEY
ORDER BY TOTAL_SPENT DESC
LIMIT 10;

--Revenue by Order Status
SELECT
    O_ORDERSTATUS,
    ROUND(SUM(O_TOTALPRICE), 2) AS TOTAL_REVENUE
FROM SILVER.ORDERS_INCREMENTAL
GROUP BY O_ORDERSTATUS
ORDER BY TOTAL_REVENUE DESC;

--Daily Sales Trend
SELECT
    O_ORDERDATE,
    ROUND(SUM(O_TOTALPRICE), 2) AS DAILY_REVENUE
FROM SILVER.ORDERS_INCREMENTAL
GROUP BY O_ORDERDATE
ORDER BY O_ORDERDATE;

--Top 5 Highest Orders
