--CREATE THE GOLD LAYER
CREATE OR REPLACE TABLE GOLD.YEAR_SALES AS SELECT ORDER_YEAR, COUNT(*) AS TOTAL_ORDERS, SUM(O_TOTALPRICE) AS TOTAL_SALES, AVG(O_TOTALPRICE) AS AVG_ORDER_VALUE
FROM SILVER.ORDERS_CLEAN
GROUP BY ORDER_YEAR;
