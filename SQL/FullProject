-- STREAMS
--CREATE A STREAM TO CHECK IF ANY NEW DATA IS ADDED. and the bronze table is auto updated
CREATE OR REPLACE STREAM ORDERS_STREAM ON TABLE BRONZE.ORDERS_RAW;
--adding new data 
INSERT INTO BRONZE.ORDERS_RAW VALUES ( 12345, 123, 'O', 12345677, '2016-05-13', '1-URGENT', 'Cleak#12345678', 0, 'new order data');
--checking stream to if any new data is added
select * from ORDERS_STREAM;

--CREATING INCREMENTAL SILVER TABLE TO UPDATE THE NEW DATA FROM BRONZE STREAM ORDER TABLE (ORDERS_STREAM)
CREATE OR REPLACE TABLE SILVER.ORDERS_INCREMENTAL (
    O_ORDERKEY NUMBER,
    O_CUSTKEY NUMBER,
    O_ORDERSTATUS STRING,
    O_TOTALPRICE NUMBER(12,2),
    O_ORDERDATE DATE,
    LOAD_TIME TIMESTAMP
);

--NOW MERGE THE STREAM DATA INTO SILVER INCREMENTAL TABLE
MERGE INTO SILVER.ORDERS_INCREMENTAL T

USING (
    SELECT
        O_ORDERKEY,
        O_CUSTKEY,
        O_ORDERSTATUS,
        O_TOTALPRICE,
        O_ORDERDATE,
        CURRENT_TIMESTAMP() AS LOAD_TIME
    FROM ORDERS_STREAM
) S

ON T.O_ORDERKEY = S.O_ORDERKEY

WHEN MATCHED THEN
UPDATE SET
    T.O_TOTALPRICE = S.O_TOTALPRICE,
    T.O_ORDERSTATUS = S.O_ORDERSTATUS,
    T.LOAD_TIME = S.LOAD_TIME

WHEN NOT MATCHED THEN
INSERT (
    O_ORDERKEY,
    O_CUSTKEY,
    O_ORDERSTATUS,
    O_TOTALPRICE,
    O_ORDERDATE,
    LOAD_TIME
)
VALUES (
    S.O_ORDERKEY,
    S.O_CUSTKEY,
    S.O_ORDERSTATUS,
    S.O_TOTALPRICE,
    S.O_ORDERDATE,
    S.LOAD_TIME
);

