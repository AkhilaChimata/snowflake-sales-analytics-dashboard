--TASKS = AUTOMATIC SQL RUNNER
--INSTEAD TO RUNNING MERGE QUERY ANUALLY EVERYTIME, WE CREATE TASKSO THAT SNOWFLAKE RUN IT AUTOMATICALLY
USE WAREHOUSE COMPUTE_WH;
--CREATE TASK
CREATE OR REPLACE TASK LOAD_INCREMENTAL_ORDERS_TASK
WAREHOUSE = COMPUTE_WH
SCHEDULE = '1 MINUTE'
AS

MERGE INTO SILVER.ORDERS_INCREMENTAL T

USING (
    SELECT
        O_ORDERKEY,
        O_CUSTKEY,
        O_ORDERSTATUS,
        O_TOTALPRICE,
        O_ORDERDATE,
        CURRENT_TIMESTAMP() AS LOAD_TIME
    FROM ORDERS_STREAM
) S

ON T.O_ORDERKEY = S.O_ORDERKEY

WHEN MATCHED THEN
UPDATE SET
    T.O_TOTALPRICE = S.O_TOTALPRICE,
    T.O_ORDERSTATUS = S.O_ORDERSTATUS,
    T.LOAD_TIME = S.LOAD_TIME

WHEN NOT MATCHED THEN
INSERT (
    O_ORDERKEY,
    O_CUSTKEY,
    O_ORDERSTATUS,
    O_TOTALPRICE,
    O_ORDERDATE,
    LOAD_TIME
)
VALUES (
    S.O_ORDERKEY,
    S.O_CUSTKEY,
    S.O_ORDERSTATUS,
    S.O_TOTALPRICE,
    S.O_ORDERDATE,
    S.LOAD_TIME
);
--START THE TASK
ALTER TASK LOAD_INCREMENTAL_ORDERS_TASK RESUME;
